# Copy to .env in this folder (client/). Values: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
#
# Auth → URL Configuration (Site URL + Redirect URLs): inclua a URL da app com o caminho de callback,
# por exemplo http://localhost:5173/auth/callback em dev ou https://app.seudominio.com/auth/callback em produção.
#
# Produção (Vercel, etc.): URL pública sem barra final — links de confirmação de registo usam isto e não localhost.
# VITE_PUBLIC_APP_URL=https://app.seudominio.com

# OpenRouter — opcional em dev: chave no bundle. Em produção use a Edge Function:
#   supabase secrets set OPENROUTER_API_KEY=sk-or-...
#   supabase functions deploy openrouter-chat
# https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=
# Optional: https://openrouter.ai/models
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini

# Novo orçamento em página externa (Typeform, site, etc.) — aparece na sidebar
# VITE_NOVO_ORCAMENTO_EXTERNAL_URL=https://exemplo.com/solicitar-orcamento
VITE_NOVO_ORCAMENTO_EXTERNAL_URL=

# Convites por e-mail (Edge Function send-org-invite-email + Resend) — só no Supabase, não no Vite:
#   supabase secrets set RESEND_API_KEY=re_...
#   supabase secrets set RESEND_FROM="EmbalaFlow <noreply@seudominio.com>"
#   Opcional (produção): restringir origem do link do convite
#   supabase secrets set APP_ALLOWED_ORIGINS=https://app.seudominio.com,https://www.seudominio.com
#   supabase functions deploy send-org-invite-email
# https://resend.com/docs/send-with-nodejs
